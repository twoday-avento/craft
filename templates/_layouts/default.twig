{% extends "_layouts/base" %}

{% block response %}
  <!DOCTYPE html>
  {% block htmlTag %}
  <html lang="{{ currentSite.language }}">
  {% endblock %}
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
      <meta name="referrer" content="origin-when-cross-origin" />

      {# -- Fallback <title> when SEOmatic is not installed -- #}
      {% if not craft.app.plugins.getPlugin('seomatic') %}
        <title>{% block title %}{{ siteName }}{% endblock %}</title>
      {% endif %}

      {# -- Any <meta> tags that should be included in the <head> -- #}
      {% block headMeta %}
      {% endblock headMeta %}

      {# -- Any <link> tags that should be included in the <head> -- #}
      {% block headLinks %}
      {% endblock headLinks %}

      {# -- Hide elements until Alpine.js loads (must be inline to prevent FOUC) -- #}
      <style>[x-cloak] { display: none !important; }</style>

      {# -- Any JavaScript that should be included before </head> -- #}
      {% block headJs %}
        {{ craft.vite.script("src/js/app.js", false) }}
      {% endblock headJs %}
    </head>
    {% block bodyTag %}
    <body>
    {% endblock %}
      {# -- Global header -- #}
      {% include "_includes/header" %}

      {# -- The page content -- #}
      {% block content %}{% endblock %}

      {# -- Global footer -- #}
      {% include "_includes/footer" %}

      {# -- Any JavaScript that should be included before </body> -- #}
      {% block bodyJs %}
      {% endblock bodyJs %}
    </body>
  </html>
{% endblock %}
