{% macro image(image, opts) %}
  {% apply spaceless %}
    {% set opts = {
      class: '',
      lazyload: true,
      sizes: [
        { width: 425 },
        { width: 768 },
        { width: 1366 },
        { width: 1920 },
      ],
      ratio: null,
      attributes: {},
      format: (image.extension not in ['svg'] and craft.imager.serverSupportsWebp() and craft.imager.clientSupports('webp')) ? 'webp' : image.extension,
    }|merge(opts) %}

    {% set transformedImages = craft.imager.transformImage(
      image,
      opts.sizes,
      {
        ratio: opts.ratio,
        format: opts.format,
        position: image.getFocalPoint(),
        jpegQuality: 85,
      },
      {
        fillTransforms: false,
      }
    ) %}

    {% set sizesAttr = opts.attributes.sizes ?? '100vw' %}

    {% set attributes = {
      alt: image.alt ?? image.title ?? '',
      class: opts.class,
      src: opts.lazyload ? craft.imager.placeholder({type: 'svg', color: 'rgba(0,0,0,.025)', width: transformedImages[0].getWidth(), height: transformedImages[0].getHeight()}) : transformedImages[0].url,
      srcset: transformedImages|srcset,
      sizes: sizesAttr,
      width: transformedImages[0].getWidth(),
      height: transformedImages[0].getHeight(),
      loading: opts.lazyload ? 'lazy' : 'eager',
    }|merge(opts.attributes) %}
  {% endapply %}

  <picture>
    <img {{ attr(attributes) }}>
  </picture>
{% endmacro %}
